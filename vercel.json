{
  "version": 2,
  "cleanUrls": false,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(assets|css|js|img|font|brandsimage)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/admin/(assets|scripts|productimages)/(.*)",
      "dest": "/admin/$1/$2"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api/admin/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
